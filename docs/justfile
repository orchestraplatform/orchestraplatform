# Documentation Tasks

# Default task
default:
    @just --list

# Development
dev:
    npm run dev

build:
    npm run build

# Quality checks
lint:
    npm run lint

format:
    npm run format

format-check:
    npm run format:check

quality: lint format-check
    @echo "✅ Documentation quality checks passed"

# Setup
install:
    npm install

clean:
    rm -rf node_modules .astro dist
