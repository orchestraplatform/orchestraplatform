# Orchestra API — local development configuration
# Copy this file to .env and adjust values for your environment.
# All variables use the ORCHESTRA_ prefix (see api/core/config.py).

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
ORCHESTRA_DEBUG=true
ORCHESTRA_HOST=0.0.0.0
ORCHESTRA_PORT=8000

# ---------------------------------------------------------------------------
# Kubernetes
# ---------------------------------------------------------------------------
# Set ORCHESTRA_IN_CLUSTER=true only when running inside a pod.
ORCHESTRA_IN_CLUSTER=false

# Path to kubeconfig file. Leave unset to use the default (~/.kube/config).
# ORCHESTRA_KUBECONFIG_PATH=

# Kubernetes context to use for local development.
# Run `kubectl config get-contexts` to see available contexts.
ORCHESTRA_KUBE_CONTEXT=docker-desktop

# ---------------------------------------------------------------------------
# Workshop defaults
# ---------------------------------------------------------------------------
ORCHESTRA_DEFAULT_WORKSHOP_IMAGE=rocker/rstudio:latest
ORCHESTRA_DEFAULT_WORKSHOP_DURATION=4h
ORCHESTRA_DEFAULT_CPU_LIMIT=1
ORCHESTRA_DEFAULT_MEMORY_LIMIT=2Gi
ORCHESTRA_DEFAULT_CPU_REQUEST=500m
ORCHESTRA_DEFAULT_MEMORY_REQUEST=1Gi
ORCHESTRA_DEFAULT_STORAGE_SIZE=10Gi

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# CHANGE THIS in any non-local environment.
ORCHESTRA_SECRET_KEY=change-me-in-production
ORCHESTRA_ALGORITHM=HS256
ORCHESTRA_ACCESS_TOKEN_EXPIRE_MINUTES=30
ORCHESTRA_REFRESH_TOKEN_EXPIRE_DAYS=7

# Disable auth for local development (set to true in staging/prod).
ORCHESTRA_REQUIRE_AUTHENTICATION=false
ORCHESTRA_ALLOW_ANONYMOUS_READ=true

# ---------------------------------------------------------------------------
# OAuth (optional — only needed when ORCHESTRA_REQUIRE_AUTHENTICATION=true)
# ---------------------------------------------------------------------------
# ORCHESTRA_OAUTH_PROVIDER=github          # github | google | oidc
# ORCHESTRA_OAUTH_CLIENT_ID=
# ORCHESTRA_OAUTH_CLIENT_SECRET=
# ORCHESTRA_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# OIDC / institutional SSO
# ORCHESTRA_OIDC_ISSUER=
# ORCHESTRA_OIDC_AUDIENCE=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Port 5433 avoids conflict with a system Postgres on 5432.
# Inside docker-compose the server reaches postgres directly on 5432.
ORCHESTRA_DATABASE_URL=postgresql+asyncpg://orchestra:orchestra@localhost:5433/orchestra

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins. Defaults to * (all origins).
# ORCHESTRA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
