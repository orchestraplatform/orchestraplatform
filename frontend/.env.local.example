# Frontend local dev configuration
# Copy this file to .env.local — Vite loads it automatically and it is gitignored.

# URL of the Orchestra API server.
# Matches the port used by `just dev-server` (avoids conflict with Docker Desktop on 8000).
VITE_API_URL=http://localhost:8080

# Google Analytics 4 measurement ID. Leave unset for local dev — analytics is
# then completely off (no script, no network calls). Production gets its ID at
# runtime from the Helm chart (frontend.gaMeasurementId), not from this file.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
